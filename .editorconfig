# ggaze editor config — mirrors docs/coding-conventions.md + .clang-format.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 3
max_line_length = 80

[*.{c,h}]
indent_size = 3

[meson.build]
indent_size = 3

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab